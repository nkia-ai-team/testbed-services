{
  "schema_version": "1.0",
  "id": "F21-Q",
  "slug": "f21-q-food-order-tomcat-thread-saturation",
  "readiness": "draft",
  "authoritative_sources": {
    "catalog": "scripts/scenarios/catalog.json",
    "execution_matrix": "docs/spec-scenario-execution-matrix.md",
    "charter": "docs/spec-scenario-design-charter.md"
  },
  "class": "A",
  "fault_pattern": "P2",
  "injection": {
    "location": "food-restaurant-slowdown",
    "matrix_location_transport": "tb-runner → host.stress(worker-w2 CPU) 또는 db.workload(restaurant MySQL) 로 restaurant-service getRestaurant/getMenu 지연 유발",
    "transport": "ssh/kubectl",
    "profile_refs": [
      "injector-profiles/host.stress",
      "injector-profiles/load.north_south"
    ],
    "injector_note": "정밀 delay_seconds injector 부재(restaurant hop엔 mock 없음). host.stress(거침) 또는 db.workload(live 미지원) 중 택1 + read-timeout 5s 미만 유지 캘리브레이션. sheet §4-C."
  },
  "execution": {
    "preflight_ids": [
      "catalog-integrity",
      "canonical-kubeconfig",
      "global-dirty-lease",
      "baseline-clean-window",
      "target-health",
      "profile-prerequisites",
      "transport-kubectl-access",
      "baseline-loadgen-active"
    ],
    "controller": {
      "dispatcher_mode": "trusted",
      "live_enabled": false,
      "binding": {
        "primary_ref": "host.stress",
        "companion_refs": ["load.north_south"],
        "approved_profile_id": "host.stress"
      },
      "runtime": {
        "mode": "evaluation",
        "tick_interval": "15s",
        "settle_after_change": "45s",
        "max_injection_duration": "15m",
        "preflight": ["kube-context", "kube-node-set", "coordinator-clean", "clean-window", "baseline-traffic", "target-health"],
        "baseline": {
          "clean_window": "30m",
          "required": [
            { "check": "coordinator-clean" },
            { "check": "clean-window" },
            { "check": "baseline-traffic" },
            { "check": "target-health" }
          ]
        },
        "must_rule_out": {
          "any": [
            { "id": "external-rate-limit", "observation": "entry_status", "op": "eq", "value": 429 },
            { "id": "hikari-pool-exhaustion", "observation": "order_hikari_pending", "op": "gt", "value": 0 },
            { "id": "dispatch-503-reject", "observation": "order_create_503_rate", "op": "gte", "value": 0.2 }
          ],
          "consecutive_ticks": 2
        },
        "abort": {
          "any": [
            { "id": "entry-unreachable", "observation": "entry_status", "op": "eq", "value": 0 }
          ],
          "consecutive_ticks": 2
        },
        "cleanup": { "required": true, "order": "reverse", "timeout": "10m" },
        "capture": {
          "enabled": true,
          "pre_window": "10m",
          "post_window": "20m",
          "model_snapshot": "/var/lib/lucida/ai-models/stream-anomaly/global/v1/model.json",
          "create_golden_anomaly": false
        },
        "profile": {
          "kind": "fixed",
          "levels": [
            {
              "id": "approved-fixed-f21-q",
              "parameters": {
                "target": "restaurant-service",
                "worker": "worker-w2",
                "mechanism": "cpu-stress-or-db-workload",
                "target_added_latency_seconds": 4,
                "latency_ceiling_seconds": 5,
                "companion_load": {
                  "entry_url": "http://192.168.122.77:30181",
                  "script_path": "/opt/loadgen/food-delivery/order-surge.js",
                  "business_step": "create",
                  "target_rps": 55,
                  "baseline_unit": "loadgen-food"
                }
              },
              "min_hold": "8m",
              "settle": "45s",
              "timeout": "13m"
            }
          ]
        },
        "observations": [
          { "id": "entry_status", "adapter": "http_probe", "query_id": "http.entry_health", "freshness": "15s" },
          {
            "id": "order_target_health", "adapter": "http_probe", "query_id": "http.target_health",
            "parameters": { "service": "testbed-order", "namespace": "rca-testbed-food", "port": 8080, "path": "/actuator/health" },
            "freshness": "15s"
          },
          {
            "id": "order_pod_ready", "adapter": "kubernetes", "query_id": "kubernetes.pod_ready",
            "parameters": { "namespace": "rca-testbed-food", "resource": "testbed-order" }, "freshness": "30s"
          },
          {
            "id": "order_busy_threads", "adapter": "prometheus", "query_id": "prometheus.http_server_active_requests",
            "parameters": { "service_name": "food-order" }, "freshness": "30s",
            "capability_gap": "NEW query_id — OTel javaagent http.server.active_requests (동시 in-flight = Tomcat busy-thread 근사). javaagent emit 여부 검증 후 등록. sheet §4-A #1."
          },
          {
            "id": "order_hikari_pending", "adapter": "prometheus", "query_id": "prometheus.hikari_pending_connections",
            "parameters": { "service_name": "food-order" }, "freshness": "30s",
            "capability_gap": "NEW query_id — F21-Q에선 pending≈0 증명용(스레드지 풀 아님, F19-P와 결정 구분). sheet §4-A #2."
          },
          {
            "id": "order_read_get_latency", "adapter": "loadgen_summary", "query_id": "loadgen.food_create_status_rate",
            "parameters": { "step": "read", "metric": "p95_latency" }, "freshness": "30s",
            "capability_gap": "NEW — 무관 GET /api/orders 지연(스레드 고갈 전염 지문). 현 food surge는 read-step 미계측. sheet §4-A #3."
          },
          {
            "id": "order_create_503_rate", "adapter": "loadgen_summary", "query_id": "loadgen.food_create_status_rate",
            "parameters": { "step": "create", "status_class": "503" }, "freshness": "30s",
            "capability_gap": "NEW query_id — dispatch 503(F19-Q) 배제용. food create per-status emit 필요. sheet §4-A #3."
          }
        ],
        "success": {
          "all": [
            { "id": "order-threads-saturated", "observation": "order_busy_threads", "op": "gte", "value": 180 },
            { "id": "order-pool-not-exhausted", "observation": "order_hikari_pending", "op": "eq", "value": 0 },
            { "id": "unrelated-get-degraded", "observation": "order_read_get_latency", "op": "gte", "value": 3 }
          ],
          "consecutive_ticks": 3
        },
        "recovery": {
          "all": [
            { "id": "order-target-recovered", "observation": "order_target_health", "op": "eq", "value": 200 },
            { "id": "order-threads-recovered", "observation": "order_busy_threads", "op": "lt", "value": 50 }
          ],
          "consecutive_ticks": 2,
          "timeout": "10m"
        }
      }
    }
  },
  "actions": {
    "plan": { "mode": "dry-run", "mutation": false, "adapter_refs": ["host.stress", "load.north_south"] },
    "run": { "mode": "dry-run", "mutation": false, "requires_preflight": true, "adapter_refs": ["host.stress", "load.north_south"] },
    "cleanup": { "mode": "dry-run", "mutation": false, "required": true, "order": "reverse", "recovery_gate": true, "adapter_refs": ["load.north_south", "host.stress"] }
  },
  "prerequisite_gate": {
    "state": "blocked",
    "required": true,
    "description": "① 지연 주입: restaurant hop엔 정밀 delay injector 없음(food mock=PG 전용) → host.stress(worker-w2) 또는 db.workload(restaurant MySQL, live 미지원)로 간접 지연 + read-timeout 5s '미만' 유지 캘리브레이션(초과 시 retry/502 → C4 regime으로 전이). host.stress allowed_scenarios(현 F09-R/F05-P)에 F21-Q + 워커 매핑 추가. ② 부하: Tomcat 200 포화엔 create ~50 req/s 지속 필요(Little L=λ·4s) → order-surge.js create-heavy + target_rps 상향, load.north_south allowed_scenarios/tag_pattern에 F21-Q 추가(food entry 30181·loadgen-food 기존 재사용). ③ 관측: NEW query 3종 — prometheus.http_server_active_requests(busy-thread), prometheus.hikari_pending_connections(pending≈0 증명=F19-P 감별), loadgen.food_create_status_rate(create 503 배제 + read-step 지연 전염). 자세히 sheet §4.",
    "live_allowed": false
  },
  "capture_policy": {
    "policy_ref": "focused-window-v1",
    "time_basis": "UTC",
    "t1": "earliest-actual-effect-start",
    "t2": "latest-load-end-or-fault-release",
    "query_window": "[t1-10m,t2+20m]",
    "export_not_before": "t2+20m",
    "model_snapshot": "/var/lib/lucida/ai-models/stream-anomaly/global/v1/model.json@t2+20m",
    "create_golden_anomaly": false,
    "allowed_case_labels": ["calibration", "evaluation", "failed"]
  }
}

  },
  "class": "A",
  "fault_pattern": "P8",
  "injection": {
    "location": "banking-loadgen",
    "matrix_location_transport": "tb-runner k6 → GATEWAY 30082 GET /api/transfers/stats/daily",
    "transport": "k6",
    "profile_refs": [
      "injector-profiles/load.north_south"
    ]
  },
  "execution": {
    "preflight_ids": [
      "catalog-integrity",
      "canonical-kubeconfig",
      "global-dirty-lease",
      "baseline-clean-window",
      "target-health",
      "profile-prerequisites",
      "transport-loadgen-access",
      "baseline-loadgen-active"
    ],
    "controller": {
      "dispatcher_mode": "trusted",
      "live_enabled": false,
      "binding": {
        "primary_ref": "load.north_south",
        "companion_refs": [],
        "approved_profile_id": "load.north_south"
      },
      "runtime": {
        "mode": "evaluation",
        "tick_interval": "15s",
        "settle_after_change": "45s",
        "max_injection_duration": "15m",
        "preflight": ["kube-context", "kube-node-set", "coordinator-clean", "clean-window", "baseline-traffic", "target-health"],
        "baseline": {
          "clean_window": "30m",
          "required": [
            { "check": "coordinator-clean" },
            { "check": "clean-window" },
            { "check": "baseline-traffic" },
            { "check": "target-health" }
          ]
        },
        "must_rule_out": {
          "any": [
            { "id": "external-rate-limit", "observation": "entry_status", "op": "eq", "value": 429 },
            { "id": "oracle-global-outage", "observation": "ledger_error_rate", "op": "gte", "value": 0.3 }
          ],
          "consecutive_ticks": 2
        },
        "abort": {
          "any": [
            { "id": "entry-unreachable", "observation": "entry_status", "op": "eq", "value": 0 }
          ],
          "consecutive_ticks": 2
        },
        "cleanup": { "required": true, "order": "reverse", "timeout": "10m" },
        "capture": {
          "enabled": true,
          "pre_window": "10m",
          "post_window": "20m",
          "model_snapshot": "/var/lib/lucida/ai-models/stream-anomaly/global/v1/model.json",
          "create_golden_anomaly": false
        },
        "profile": {
          "kind": "fixed",
          "levels": [
            {
              "id": "approved-fixed-f20-p",
              "parameters": {
                "target_rps": 20,
                "ramp_up": "2m",
                "hold": "8m",
                "ramp_down": "1m",
                "entry_url": "http://192.168.122.77:30082",
                "script_path": "/opt/loadgen/core-banking/slowquery.js",
                "scenario_tag": "scenario_id=F20-P",
                "seed": 4242,
                "baseline_unit": "loadgen-banking"
              },
              "min_hold": "8m",
              "settle": "45s",
              "timeout": "13m"
            }
          ]
        },
        "observations": [
          { "id": "entry_status", "adapter": "http_probe", "query_id": "http.entry_health", "freshness": "15s" },
          {
            "id": "transfer_target_health", "adapter": "http_probe", "query_id": "http.target_health",
            "parameters": { "service": "testbed-transfer", "namespace": "rca-testbed-banking", "port": 8082, "path": "/actuator/health" },
            "freshness": "15s"
          },
          {
            "id": "transfer_p95", "adapter": "prometheus", "query_id": "prometheus.apm_service_p95",
            "parameters": { "service_name": "core-banking-transfer" }, "freshness": "60s"
          },
          {
            "id": "account_error_rate", "adapter": "prometheus", "query_id": "prometheus.apm_service_error_rate",
            "parameters": { "service_name": "core-banking-account" }, "freshness": "60s"
          },
          {
            "id": "api_error_rate", "adapter": "prometheus", "query_id": "prometheus.apm_service_error_rate",
            "parameters": { "service_name": "core-banking-api" }, "freshness": "60s"
          },
          {
            "id": "ledger_error_rate", "adapter": "prometheus", "query_id": "prometheus.apm_service_error_rate",
            "parameters": { "service_name": "core-banking-ledger" }, "freshness": "60s"
          },
          {
            "id": "transfer_hikari_pending", "adapter": "prometheus", "query_id": "prometheus.hikari_pending_connections",
            "parameters": { "service_name": "core-banking-transfer" }, "freshness": "30s",
            "capability_gap": "NEW query_id — transfer Hikari(15) active/pending 게이지. 통계 풀스캔의 커넥션 점유가 결정 신호. F19-P가 올린 동일 갭. OTel javaagent hikaricp_connections_pending 노출 확인 후 등록. sheet §4-B #5."
          },
          {
            "id": "transfer_slowquery_read_rate", "adapter": "loadgen_summary", "query_id": "loadgen.read_step_status_rate",
            "parameters": { "step": "stats-daily", "status_class": "5xx" }, "freshness": "30s",
            "capability_gap": "NEW loadgen 배선 — banking surge.js는 balance/history/list/transfer만 침. /api/transfers/stats/daily를 치는 slowquery.js 신설 + read-step emit + load.north_south 계약 등록 필요. sheet §4-A."
          }
        ],
        "success": {
          "all": [
            { "id": "transfer-latency-up", "observation": "transfer_p95", "op": "gte", "value": 3.0 },
            { "id": "account-502-up", "observation": "account_error_rate", "op": "gte", "value": 0.1 },
            { "id": "transfer-pool-occupied", "observation": "transfer_hikari_pending", "op": "gt", "value": 0 }
          ],
          "consecutive_ticks": 3
        },
        "recovery": {
          "all": [
            { "id": "transfer-target-recovered", "observation": "transfer_target_health", "op": "eq", "value": 200 },
            { "id": "transfer-latency-recovered", "observation": "transfer_p95", "op": "lt", "value": 1.0 },
            { "id": "account-recovered", "observation": "account_error_rate", "op": "lt", "value": 0.02 }
          ],
          "consecutive_ticks": 2,
          "timeout": "10m"
        }
      }
    }
  },
  "actions": {
    "plan": { "mode": "dry-run", "mutation": false, "adapter_refs": ["load.north_south"] },
    "run": { "mode": "dry-run", "mutation": false, "requires_preflight": true, "adapter_refs": ["load.north_south"] },
    "cleanup": { "mode": "dry-run", "mutation": false, "required": true, "order": "reverse", "recovery_gate": true, "adapter_refs": ["load.north_south"] }
  },
  "prerequisite_gate": {
    "state": "blocked",
    "required": true,
    "description": "④ 주입: NEW loadgen 스크립트 필요 — banking surge.js는 balance/history/list/transfer만 침. GET /api/transfers/stats/daily?days=90을 치는 slowquery.js 신설 + load.north_south 계약 등록(allowed_scenarios F20-P, allowed_script_paths /opt/loadgen/core-banking/slowquery.js, scenario_parameters entry 30082/loadgen-banking, tag_pattern 확장). banking은 domain_profiles/entry(30082)/baseline_unit 이미 등록. ③ 관측: prometheus.hikari_pending_connections(transfer 커넥션 점유 — F19-P와 동일 갭) + DB-side Oracle 쿼리시간 query 신설. 진짜 injector 능력갭 아님(전부 배선). 자세히 sheet §4.",
    "live_allowed": false
  },
  "capture_policy": {
    "policy_ref": "focused-window-v1",
    "time_basis": "UTC",
    "t1": "earliest-actual-effect-start",
    "t2": "latest-load-end-or-fault-release",
    "query_window": "[t1-10m,t2+20m]",
    "export_not_before": "t2+20m",
    "model_snapshot": "/var/lib/lucida/ai-models/stream-anomaly/global/v1/model.json@t2+20m",

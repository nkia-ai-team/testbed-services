{
  "schema_version": "1.0",
  "id": "F20-Q",
  "slug": "f20-q-food-order-unpaged-slowquery-heap-pressure",
  "readiness": "draft",
  "authoritative_sources": {
    "catalog": "scripts/scenarios/catalog.json",
    "execution_matrix": "docs/spec-scenario-execution-matrix.md",
    "charter": "docs/spec-scenario-design-charter.md"
  },
  "class": "A",
  "fault_pattern": "P8",
  "injection": {
    "location": "food-loadgen",
    "matrix_location_transport": "tb-runner k6 → order 30180 GET /api/orders(unpaged) + GET /api/orders/stats/daily (entry health 30181)",
    "transport": "k6",
    "profile_refs": [
      "injector-profiles/load.north_south"
    ]
  },
  "execution": {
    "preflight_ids": [
      "catalog-integrity",
      "canonical-kubeconfig",
      "global-dirty-lease",
      "baseline-clean-window",
      "target-health",
      "profile-prerequisites",
      "transport-loadgen-access",
      "baseline-loadgen-active"
    ],
    "controller": {
      "dispatcher_mode": "trusted",
      "live_enabled": false,
      "binding": {
        "primary_ref": "load.north_south",
        "companion_refs": [],
        "approved_profile_id": "load.north_south"
      },
      "runtime": {
        "mode": "evaluation",
        "tick_interval": "15s",
        "settle_after_change": "45s",
        "max_injection_duration": "15m",
        "preflight": ["kube-context", "kube-node-set", "coordinator-clean", "clean-window", "baseline-traffic", "target-health"],
        "baseline": {
          "clean_window": "30m",
          "required": [
            { "check": "coordinator-clean" },
            { "check": "clean-window" },
            { "check": "baseline-traffic" },
            { "check": "target-health" }
          ]
        },
        "must_rule_out": {
          "any": [
            { "id": "external-rate-limit", "observation": "entry_status", "op": "eq", "value": 429 },
            { "id": "payment-5xx-cascade", "observation": "payment_error_rate", "op": "gte", "value": 0.2 },
            { "id": "dispatch-capacity-503", "observation": "order_create_503_rate", "op": "gte", "value": 0.3 }
          ],
          "consecutive_ticks": 2
        },
        "abort": {
          "any": [
            { "id": "entry-unreachable", "observation": "entry_status", "op": "eq", "value": 0 }
          ],
          "consecutive_ticks": 2
        },
        "cleanup": { "required": true, "order": "reverse", "timeout": "10m" },
        "capture": {
          "enabled": true,
          "pre_window": "10m",
          "post_window": "20m",
          "model_snapshot": "/var/lib/lucida/ai-models/stream-anomaly/global/v1/model.json",
          "create_golden_anomaly": false
        },
        "profile": {
          "kind": "fixed",
          "levels": [
            {
              "id": "approved-fixed-f20-q",
              "parameters": {
                "target_rps": 30,
                "ramp_up": "2m",
                "hold": "8m",
                "ramp_down": "1m",
                "entry_url": "http://192.168.122.77:30181",
                "script_path": "/opt/loadgen/food-delivery/slowquery.js",
                "scenario_tag": "scenario_id=F20-Q",
                "seed": 4242,
                "baseline_unit": "loadgen-food"
              },
              "min_hold": "8m",
              "settle": "45s",
              "timeout": "13m"
            }
          ]
        },
        "observations": [
          { "id": "entry_status", "adapter": "http_probe", "query_id": "http.entry_health", "freshness": "15s" },
          {
            "id": "order_target_health", "adapter": "http_probe", "query_id": "http.target_health",
            "parameters": { "service": "testbed-order", "namespace": "rca-testbed-food", "port": 8080, "path": "/actuator/health" },
            "freshness": "15s"
          },
          {
            "id": "order_p95", "adapter": "prometheus", "query_id": "prometheus.apm_service_p95",
            "parameters": { "service_name": "food-order" }, "freshness": "60s"
          },
          {
            "id": "order_memory_current", "adapter": "kubernetes", "query_id": "kubernetes.container_memory_current_bytes",
            "parameters": { "namespace": "rca-testbed-food", "deployment": "testbed-order", "container": "order-service" }, "freshness": "30s"
          },
          {
            "id": "order_memory_limit", "adapter": "kubernetes", "query_id": "kubernetes.deployment_container_memory_limit",
            "parameters": { "namespace": "rca-testbed-food", "deployment": "testbed-order", "container": "order-service" }, "freshness": "30s"
          },
          {
            "id": "order_restart_count", "adapter": "kubernetes", "query_id": "kubernetes.container_restart_count",
            "parameters": { "namespace": "rca-testbed-food", "deployment": "testbed-order", "container": "order-service" }, "freshness": "30s"
          },
          {
            "id": "payment_error_rate", "adapter": "prometheus", "query_id": "prometheus.apm_service_error_rate",
            "parameters": { "service_name": "food-payment", "status_class": "502" }, "freshness": "60s"
          },
          {
            "id": "order_create_503_rate", "adapter": "loadgen_summary", "query_id": "loadgen.food_create_status_rate",
            "parameters": { "step": "create", "status_class": "503" }, "freshness": "30s"
          },
          {
            "id": "order_slowquery_read_rate", "adapter": "loadgen_summary", "query_id": "loadgen.read_step_status_rate",
            "parameters": { "step": "orders-unpaged", "status_class": "5xx" }, "freshness": "30s",
            "capability_gap": "NEW loadgen 배선 — food surge.js/order-surge.js는 restaurants·order create·deliveries만 침. GET /api/orders(unpaged)·/api/orders/stats/daily를 치는 slowquery.js 신설 + read-step emit + load.north_south 계약 등록 필요. sheet §4-A."
          }
        ],
        "success": {
          "all": [
            { "id": "order-latency-up", "observation": "order_p95", "op": "gte", "value": 2.0 },
            { "id": "order-memory-climbing", "observation": "order_memory_current", "op": "gte", "value": 805306368 },
            { "id": "payment-not-5xx", "observation": "payment_error_rate", "op": "lt", "value": 0.05 }
          ],
          "consecutive_ticks": 3
        },
        "recovery": {
          "all": [
            { "id": "order-target-recovered", "observation": "order_target_health", "op": "eq", "value": 200 },
            { "id": "order-latency-recovered", "observation": "order_p95", "op": "lt", "value": 0.8 },
            { "id": "order-memory-recovered", "observation": "order_memory_current", "op": "lt", "value": 671088640 }
          ],
          "consecutive_ticks": 2,
          "timeout": "10m"
        }
      }
    }
  },
  "actions": {
    "plan": { "mode": "dry-run", "mutation": false, "adapter_refs": ["load.north_south"] },
    "run": { "mode": "dry-run", "mutation": false, "requires_preflight": true, "adapter_refs": ["load.north_south"] },
    "cleanup": { "mode": "dry-run", "mutation": false, "required": true, "order": "reverse", "recovery_gate": true, "adapter_refs": ["load.north_south"] }
  },
  "prerequisite_gate": {
    "state": "blocked",
    "required": true,
    "description": "④ 주입: NEW loadgen 스크립트 필요 — food surge.js/order-surge.js는 restaurants·order create(POST)·deliveries만 침. GET /api/orders(page/size 없이)·GET /api/orders/stats/daily?days=90을 치는 slowquery.js 신설 + load.north_south 계약 등록(allowed_scenarios F20-Q, allowed_script_paths /opt/loadgen/food-delivery/slowquery.js, scenario_parameters entry 30181/order 30180/loadgen-food, tag_pattern 확장). food는 entry(30181)/baseline_unit 이미 등록(F02-P 선례). ③ 관측: 힙 압박은 kubernetes.container_memory_current_bytes + limit로 관측 가능(3종 중 최선), 잔여 갭은 read-step status emit + DB-side MySQL slow query query. 진짜 injector 능력갭 아님(전부 배선). 자세히 sheet §4. 주: memory 임계 805306368=0.75Gi(1Gi limit의 75%), recovery 671088640=0.625Gi.",
    "live_allowed": false
  },
  "capture_policy": {
    "policy_ref": "focused-window-v1",
    "time_basis": "UTC",
    "t1": "earliest-actual-effect-start",
    "t2": "latest-load-end-or-fault-release",
    "query_window": "[t1-10m,t2+20m]",
    "export_not_before": "t2+20m",
    "model_snapshot": "/var/lib/lucida/ai-models/stream-anomaly/global/v1/model.json@t2+20m",
    "create_golden_anomaly": false,
    "allowed_case_labels": ["calibration", "evaluation", "failed"]
  }

{
  "schema_version": "1.0",
  "adapters": {
    "loadgen_summary": {
      "required_fields": [
        "value",
        "observed_at",
        "source",
        "freshness",
        "quality"
      ]
    },
    "http_probe": {
      "required_fields": [
        "value",
        "observed_at",
        "source",
        "freshness",
        "quality"
      ]
    },
    "prometheus": {
      "required_fields": [
        "value",
        "observed_at",
        "source",
        "freshness",
        "quality"
      ],
      "raw_promql_allowed": false
    },
    "kubernetes": {
      "required_fields": [
        "value",
        "observed_at",
        "source",
        "freshness",
        "quality"
      ]
    },
    "database": {
      "required_fields": [
        "value",
        "observed_at",
        "source",
        "freshness",
        "quality"
      ]
    },
    "business_probe": {
      "required_fields": [
        "value",
        "observed_at",
        "source",
        "freshness",
        "quality"
      ]
    },
    "capture_status": {
      "required_fields": [
        "value",
        "observed_at",
        "source",
        "freshness",
        "quality"
      ]
    }
  },
  "queries": {
    "loadgen.achieved_rps": {
      "adapter": "loadgen_summary",
      "selector": "iterations.rate",
      "value_type": "number",
      "freshness_sec": 30
    },
    "loadgen.checkout_5xx_rate": {
      "adapter": "loadgen_summary",
      "selector": "checkout.5xx.rate",
      "value_type": "number",
      "freshness_sec": 30
    },
    "http.entry_health": {
      "adapter": "http_probe",
      "request_ref": "scenario.entry_health",
      "value_type": "integer",
      "freshness_sec": 15
    },
    "http.target_health": {
      "adapter": "http_probe",
      "request_ref": "scenario.target_health",
      "value_type": "integer",
      "freshness_sec": 15
    },
    "prometheus.user_p95": {
      "adapter": "prometheus",
      "template_id": "http-server-duration-p95-v1",
      "promql_template": "histogram_quantile(0.95, sum by (le) (rate(http_server_request_duration_seconds_bucket{service_name=~\"{{service_name}}\"}[2m])))",
      "allowed_parameters": [
        "service_name"
      ],
      "value_type": "number",
      "freshness_sec": 60
    },
    "prometheus.apm_service_p95": {
      "adapter": "prometheus",
      "template_id": "apm-agent-percentile95-v1",
      "allowed_parameters": [
        "service_name"
      ],
      "value_type": "number",
      "freshness_sec": 60
    },
    "prometheus.node_cpu_utilization": {
      "adapter": "prometheus",
      "template_id": "kcm-node-cpu-utilization-v1",
      "allowed_parameters": [
        "node"
      ],
      "value_type": "number",
      "freshness_sec": 60
    },
    "prometheus.apm_service_error_rate": {
      "adapter": "prometheus",
      "template_id": "apm-agent-error-rate-v1",
      "allowed_parameters": [
        "service_name"
      ],
      "value_type": "number",
      "freshness_sec": 60
    },
    "prometheus.container_cpu_throttled_time": {
      "adapter": "prometheus",
      "template_id": "kcm-pod-cpu-throttled-time-v1",
      "allowed_parameters": [
        "namespace",
        "deployment",
        "container"
      ],
      "value_type": "number",
      "freshness_sec": 60
    },
    "prometheus.pod_network_error_rate": {
      "adapter": "prometheus",
      "template_id": "kcm-workload-network-error-rate-v1",
      "allowed_parameters": [
        "namespace",
        "deployment"
      ],
      "value_type": "number",
      "freshness_sec": 60
    },
    "kubernetes.pod_ready": {
      "adapter": "kubernetes",
      "selector": "pod.condition.Ready",
      "value_type": "boolean",
      "freshness_sec": 30
    },
    "kubernetes.deployment_container_cpu_limit": {
      "adapter": "kubernetes",
      "selector": "deployment.container.resources.limits.cpu",
      "allowed_parameters": [
        "namespace",
        "deployment",
        "container"
      ],
      "value_type": "string",
      "freshness_sec": 30
    },
    "kubernetes.image_pull_failure": {
      "adapter": "kubernetes",
      "selector": "pod.container.waiting.image_pull_failure",
      "value_type": "boolean",
      "freshness_sec": 30
    },
    "kubernetes.deployment_available_replicas": {
      "adapter": "kubernetes",
      "selector": "deployment.status.available_replicas",
      "allowed_parameters": [
        "namespace",
        "deployment"
      ],
      "value_type": "integer",
      "freshness_sec": 30
    },
    "kubernetes.kafka_consumer_lag": {
      "adapter": "kubernetes",
      "selector": "kafka.consumer_group.total_lag",
      "allowed_parameters": [
        "namespace",
        "pod",
        "bootstrap_server",
        "consumer_group"
      ],
      "value_type": "integer",
      "freshness_sec": 30
    },
    "kubernetes.container_restart_count": {
      "adapter": "kubernetes",
      "selector": "pod.container.restart_count",
      "allowed_parameters": [
        "namespace",
        "deployment",
        "container"
      ],
      "value_type": "integer",
      "freshness_sec": 30
    },
    "kubernetes.container_last_termination_reason": {
      "adapter": "kubernetes",
      "selector": "pod.container.last_termination_reason",
      "allowed_parameters": [
        "namespace",
        "deployment",
        "container"
      ],
      "value_type": "string",
      "freshness_sec": 30
    },
    "kubernetes.container_memory_current_bytes": {
      "adapter": "kubernetes",
      "selector": "pod.container.cgroup.memory_current_bytes",
      "allowed_parameters": [
        "namespace",
        "deployment",
        "container"
      ],
      "value_type": "integer",
      "freshness_sec": 30
    },
    "kubernetes.deployment_container_memory_limit": {
      "adapter": "kubernetes",
      "selector": "deployment.container.resources.limits.memory",
      "allowed_parameters": [
        "namespace",
        "deployment",
        "container"
      ],
      "value_type": "string",
      "freshness_sec": 30
    },
    "kubernetes.deployment_resources_match_baseline": {
      "adapter": "kubernetes",
      "selector": "deployment.container.resources.matches_f05_baseline",
      "allowed_parameters": [
        "namespace",
        "deployment",
        "container"
      ],
      "value_type": "boolean",
      "freshness_sec": 30
    },
    "kubernetes.deployment_liveness_probe_matches_baseline": {
      "adapter": "kubernetes",
      "selector": "deployment.container.liveness_probe.matches_f05_baseline",
      "allowed_parameters": [
        "namespace",
        "deployment",
        "container"
      ],
      "value_type": "boolean",
      "freshness_sec": 30
    },
    "database.tagged_session_count": {
      "adapter": "database",
      "selector": "scenario_tag.session_count",
      "allowed_parameters": [
        "scenario_tag"
      ],
      "value_type": "integer",
      "freshness_sec": 30
    },
    "database.index_present": {
      "adapter": "database",
      "selector": "postgres.index.present",
      "allowed_parameters": [
        "db_host",
        "db_port",
        "db_name",
        "db_user",
        "schema",
        "table",
        "index"
      ],
      "value_type": "boolean",
      "freshness_sec": 30
    },
    "business.checkout_invariant": {
      "adapter": "business_probe",
      "selector": "checkout.final_state_consistent",
      "value_type": "boolean",
      "freshness_sec": 60
    },
    "mock.transient_consumed_count": {
      "adapter": "business_probe",
      "selector": "mock.pulse_state.transient_consumed_count",
      "allowed_parameters": [
        "scenario_id"
      ],
      "value_type": "integer",
      "freshness_sec": 30
    },
    "mock.pulse_age_seconds": {
      "adapter": "business_probe",
      "selector": "mock.pulse_state.age_seconds",
      "allowed_parameters": [
        "scenario_id"
      ],
      "value_type": "number",
      "freshness_sec": 30
    },
    "mock.duplicate_expectation_count": {
      "adapter": "business_probe",
      "selector": "mock.pulse_state.duplicate_expectation_count",
      "allowed_parameters": [
        "scenario_id"
      ],
      "value_type": "integer",
      "freshness_sec": 30
    },
    "mock.expired_unconsumed_count": {
      "adapter": "business_probe",
      "selector": "mock.pulse_state.expired_unconsumed_count",
      "allowed_parameters": [
        "scenario_id"
      ],
      "value_type": "integer",
      "freshness_sec": 30
    },
    "mock.transient_expectation_absent": {
      "adapter": "business_probe",
      "selector": "mock.pulse_state.transient_expectation_absent",
      "allowed_parameters": [
        "scenario_id"
      ],
      "value_type": "boolean",
      "freshness_sec": 30
    },
    "mock.snapshot_restored": {
      "adapter": "business_probe",
      "selector": "mock.pulse_state.snapshot_restored",
      "allowed_parameters": [
        "scenario_id"
      ],
      "value_type": "boolean",
      "freshness_sec": 30
    },
    "database.payment_duplicate_order_count_since_t1": {
      "adapter": "database",
      "selector": "payment.duplicate_order_count_since_t1",
      "allowed_parameters": [
        "scenario_id",
        "run_id",
        "t1"
      ],
      "value_type": "integer",
      "freshness_sec": 30
    },
    "capture.export_complete": {
      "adapter": "capture_status",
      "selector": "export.checksum_verified",
      "value_type": "boolean",
      "freshness_sec": 60
    },
    "prometheus.node_memory_utilization": {
      "adapter": "prometheus",
      "template_id": "kcm-node-memory-utilization-v1",
      "allowed_parameters": [
        "node"
      ],
      "value_type": "number",
      "freshness_sec": 60
    },
    "kubernetes.node_ready": {
      "adapter": "kubernetes",
      "value_type": "boolean",
      "allowed_parameters": [
        "node"
      ],
      "freshness_sec": 30
    },
    "scenario.mock_flap_episode": {
      "adapter": "business_probe",
      "selector": "scenario_state.mock_flap.episode",
      "allowed_parameters": [
        "scenario_id"
      ],
      "value_type": "integer",
      "freshness_sec": 30
    },
    "scenario.mock_flap_fault_active": {
      "adapter": "business_probe",
      "selector": "scenario_state.mock_flap.fault_active",
      "allowed_parameters": [
        "scenario_id"
      ],
      "value_type": "boolean",
      "freshness_sec": 30
    },
    "business.order_duplicate_count_since_t1": {
      "adapter": "database",
      "selector": "order.duplicate_business_key_count_since_t1",
      "allowed_parameters": [
        "scenario_id",
        "run_id",
        "t1"
      ],
      "value_type": "integer",
      "freshness_sec": 60
    }
  }
}

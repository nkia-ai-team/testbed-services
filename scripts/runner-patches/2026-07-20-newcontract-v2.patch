+    script = tmp_path / "scenario.sh"
+    script.write_text(
+        "#!/bin/sh\n"
+        "if [ \"${1:-}\" = cleanup ]; then\n"
+        f"  echo cleanup >> {counter}\n"
+        f"  [ -f {allow_cleanup} ] && exit 0\n"
+        "  exit 3\n"
+        "fi\n"
+        "exit 2\n",
+        encoding="utf-8",
+    )

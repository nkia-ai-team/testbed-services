+# leading [t1-10m, t1] window must be clean. A dirty verdict re-checks every 5m;
+# after PREFLIGHT_MAX_ATTEMPTS the scenario is skipped and the queue continues.
+PREFLIGHT_RECHECK_INTERVAL = timedelta(minutes=5)

+PREFLIGHT_WINDOW_LEAD = timedelta(minutes=10)
+# Scenario spacing contract v2 (spec-scenario-load R6, 2026-07-20): the old 2h
+# inter-scenario clean window is replaced by a minimum 30m gap between the
